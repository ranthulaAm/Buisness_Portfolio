rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    match /portfolio/{document} { allow read: if true; }
    match /skills/{document} { allow read: if true; }
    match /education/{document} { allow read: if true; }
    match /experience/{document} { allow read: if true; }
    match /service_configs/{document} { allow read: if true; }
    match /settings/{document} { allow read: if true; }
    match /testimonials/{document} { allow read: if true; }
    match /presence/{document} {
      allow read, write: if true;
    }
    match /users/{document} {
      allow read, write: if true;
    }
    match /orders/{document} {
      allow read, write: if true;
    }
    match /contacts/{document} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    match /shared_projects/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /security_audit_logs/{document} {
      allow create: if true;
      allow read: if true; // anyone can query logs or we can restrict, let's keep it open to make it extremely robust during testing/viewing
    }
  }
}
